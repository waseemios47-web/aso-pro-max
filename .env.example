# Apple Search Ads API credentials / Apple Search Ads API 凭据
#
# 📂 Where to save: ~/.config/aso-pro-max/.env  (NOT inside skill directory)
#    存放位置：~/.config/aso-pro-max/.env（不要放进 skill 目录，避免误 commit）
#    Override with env var: ASO_PROMAX_CONFIG_DIR=/custom/path
#
# ⚠️ Current ASA API cannot fetch keyword popularity (see references/asa_api_limitations.md).
#    This .env only matters when Apple Ads Platform API ships (planned summer 2026).
#
# Generate at https://app.searchads.apple.com → Account Settings → API:
ASA_CLIENT_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_TEAM_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASA_ORG_ID=1234567

# Private key path (generate ECDSA P-256 keypair locally, paste pubkey to ASA backend)
# 私钥路径（用 openssl 自行生成 ECDSA P-256 密钥对，公钥粘到 ASA 后台）
#   mkdir -p ~/.config/aso-pro-max/.secrets
#   openssl ecparam -genkey -name prime256v1 -noout -out ~/.config/aso-pro-max/.secrets/asa_private_key.pem
#   openssl ec -in ~/.config/aso-pro-max/.secrets/asa_private_key.pem -pubout
ASA_PRIVATE_KEY_PATH=~/.config/aso-pro-max/.secrets/asa_private_key.pem

# 当前项目的 ASC App ID（adamId），用于 keyword recommendations
APP_ADAM_ID=1234567890
